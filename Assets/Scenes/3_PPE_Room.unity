  - {fileID: 440611248}
  trainingButtonText: {fileID: 2132878748}
  trainingButton: {fileID: 478288265}
  backButton: {fileID: 1170561418}
  trainingChoiceTitle: "\uD6C8\uB828 \uC2DC\uB098\uB9AC\uC624 \uC120\uD0DD"
  trainingChoiceDescription: "\uC9C4\uD589\uD560 \uAD50\uC721 \uC2DC\uB098\uB9AC\uC624\uB97C
    \uC120\uD0DD\uD574 \uC8FC\uC138\uC694."
  incompletePpeButton: {fileID: 1300466687}
  standardTrainingButton: {fileID: 95877509}
  trainingChoiceBackButton: {fileID: 531193965}
  scenarios:
  - selectionButtons:
    - {fileID: 6600001004}
    number: 1
    title: "\uD654\uD559\uBB3C\uC9C8 \uD654\uC7AC \uBC1C\uC0DD \uC2DC\n\uC18C\uD654
      \uC57D\uC81C \uC120\uD0DD \uBC0F \uC9C4\uC555 \uD6C8\uB828"
    description: "\uD654\uD559\uBB3C\uC9C8 \uD654\uC7AC \uBC1C\uC0DD \uC2DC \uC18C\uD654
      \uC57D\uC81C \uC120\uD0DD \uBC0F \uC9C4\uC555 \uD6C8\uB828\n\uD2B9\uC815 \uC720\uAE30\uC6A9\uC81C\uB098
      \uAE08\uC18D\uC131(\uBB3C\uACFC \uBC18\uC751\uD558\uB294) \uD654\uD559\uBB3C\uC9C8
      \uBCF4\uAD00\uC18C\uC5D0\uC11C \uD654\uC7AC\uAC00 \uBC1C\uC0DD\uD55C \uC0C1\uD669.\n\uBD88\uC774
      \uB0AC\uC744 \uB54C \uBB34\uC870\uAC74 \uBB3C\uC744 \uBFCC\uB9AC\uB294 \uAC83\uC774
      \uC544\uB2C8\uB77C, \uD654\uD559\uBB3C\uC9C8 \uC885\uB958\uC5D0 \uB9DE\uB294
      \uC18C\uD654\uAE30(CO2, \uBD84\uB9D0, \uD33D\uCC3D\uC9C8\uC11D \uB4F1)\uB97C
      \uC815\uD655\uD788 \uC120\uD0DD\uD558\uC5EC \uCD08\uAE30 \uC9C4\uC555\uC744
      \uCCB4\uD5D8\uD569\uB2C8\uB2E4."
    trainingButtonLabel: "\uD6C8\uB828 \uC120\uD0DD"
    onTrainingSelected:
      m_PersistentCalls:
        m_Calls: []
    onIncompletePpeScenarioSelected:
      m_PersistentCalls:
        m_Calls: []
    onStandardTrainingScenarioSelected:
      m_PersistentCalls:
        m_Calls: []
  - selectionButtons:
    - {fileID: 6600001104}
    number: 2
    title: "\uBC00\uD3D0\uACF5\uAC04 \uC791\uC5C5 \uC804\n\uAC1C\uC778\uBCF4\uD638\uAD6C
      \uC120\uD0DD \uBC0F \uCC29\uC6A9 \uD6C8\uB828"
    description: "\uC791\uC5C5 \uD658\uACBD\uC758 \uC720\uD574 \uC694\uC778\uC744
      \uD655\uC778\uD558\uACE0 \uD544\uC694\uD55C \uAC1C\uC778\uBCF4\uD638\uAD6C\uB97C
      \uC120\uD0DD\uD569\uB2C8\uB2E4.\n\uBCF4\uD638\uAD6C\uC758 \uC190\uC0C1 \uC5EC\uBD80\uC640
      \uBC00\uCC29 \uC0C1\uD0DC\uB97C \uC810\uAC80\uD55C \uB4A4 \uC62C\uBC14\uB978
      \uC21C\uC11C\uB85C \uCC29\uC6A9\uD569\uB2C8\uB2E4."
    trainingButtonLabel: "\uD6C8\uB828 \uC120\uD0DD"
    onTrainingSelected:
      m_PersistentCalls:
        m_Calls: []
    onIncompletePpeScenarioSelected:
      m_PersistentCalls:
        m_Calls: []
    onStandardTrainingScenarioSelected:
      m_PersistentCalls:
        m_Calls: []
  - selectionButtons:
    - {fileID: 6600001204}
    number: 3
    title: "\uBE44\uC0C1 \uC0C1\uD669 \uBC1C\uC0DD \uC2DC\n\uB300\uD53C \uC808\uCC28
      \uBC0F \uBCF4\uACE0 \uD6C8\uB828"
    description: "\uACBD\uBCF4\uC640 \uD604\uC7A5 \uC704\uD5D8 \uC694\uC18C\uB97C
      \uD655\uC778\uD558\uACE0 \uC9C0\uC815\uB41C \uB300\uD53C \uACBD\uB85C\uB85C
      \uC774\uB3D9\uD569\uB2C8\uB2E4.\n\uC548\uC804 \uAD6C\uC5ED \uB3C4\uCC29 \uD6C4
      \uC778\uC6D0\uC744 \uD655\uC778\uD558\uACE0 \uBE44\uC0C1 \uC5F0\uB77D \uCCB4\uACC4\uC5D0
      \uB530\uB77C \uC0C1\uD669\uC744 \uBCF4\uACE0\uD569\uB2C8\uB2E4."
    trainingButtonLabel: "\uD6C8\uB828 \uC120\uD0DD"
